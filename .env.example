# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: The token for the Telegram bot to send notifications.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# TELEGRAM_CHAT_ID: The ID of the Telegram chat to send notifications to.
TELEGRAM_CHAT_ID="8141432907"
